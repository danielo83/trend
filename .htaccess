# Proteggi file sensibili dall'accesso web
<FilesMatch "^\.env$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.htaccess$">
    Require all denied
</FilesMatch>

# Blocca accesso a file di database, log, jsonl e backup
<FilesMatch "\.(sqlite|log|jsonl|bak)$">
    Require all denied
</FilesMatch>

# Blocca accesso diretto a data/ e logs/
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^data/ - [F,L]
    RewriteRule ^logs/ - [F,L]
    RewriteRule ^src/ - [F,L]
</IfModule>

# Blocca directory listing
Options -Indexes
